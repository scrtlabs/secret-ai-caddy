# ============================================================
# SecretAI Caddy + Mock LLM — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === API Master Key ===
# Base64-encoded "email:password" used for Bearer token auth
# Example: echo -n "admin@example.com:MyPassword" | base64
SECRET_API_MASTER_KEY=

# === Secret Network Permit (for contract queries) ===
# Generate via SecretAI portal or secretjs
SECRETAI_MASTER_KEYS=
SECRETAI_PERMIT_TYPE=tendermint/PubKeySecp256k1
SECRETAI_PERMIT_PUBKEY=
SECRETAI_PERMIT_SIG=

# === Secret Network ===
SECRET_NODE=rpc12.scrtlabs.com
SECRET_CHAIN_ID=secret-4
SECRET_CONTRACT=secret18xpp2kmkk7g8xzx24wm5zstw9tjv6g3xle2vjm

# === DevPortal / x402 Payment Protocol ===
DEVPORTAL_URL=https://aidev.scrtlabs.com
DEVPORTAL_SERVICE_KEY=
X402_ENABLED=true
X402_MIN_BALANCE_USD=0.001

# === Metering interval ===
# How often ResilientReporter sends batched usage to portal (1m, 30s, 5m, etc.)
METERING_INTERVAL=1m

# === TLS certificate directory ===
# For self-signed: leave as ./certs, place fullchain.pem + privkey.pem there
# For Let's Encrypt on a server:
#   CERT_DIR=/etc/letsencrypt/live/yourdomain.com
CERT_DIR=./certs

# ── test_flows.sh credentials ─────────────────────────────────────────────────
# Agent wallet with funded balance on portal
TEST_AGENT_PRIVKEY=0xyour-private-key-here
TEST_AGENT_WALLET=0xyour-wallet-address-here

# User Bearer API key registered in Secret Network contract
TEST_API_KEY=sk-your-api-key-here
